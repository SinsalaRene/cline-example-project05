{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "newProjectRoot": "projects",
    "projects": {
        "fw-portal": {
            "projectType": "application",
            "schematics": {},
            "root": "",
            "sourceRoot": "src",
            "prefix": "app",
            "architect": {
                "build": {
                    "builder": "@angular-devkit/build-angular:application",
                    "options": {
                        "outputPath": "dist",
                        "index": "src/index.html",
                        "polyfills": [
                            "src/polyfills.ts"
                        ],
                        "tsConfig": "tsconfig.app.json",
                        "assets": [
                            "src/favicon.ico",
                            "src/assets"
                        ],
                        "styles": [
                            "@angular/material/prebuilt-themes/deeppurple-amber.css",
                            "node_modules/bootstrap/dist/css/bootstrap.css",
                            "src/styles.css"
                        ],
                        "scripts": [],
                        "browser": "src/main.ts"
                    },
                    "configurations": {
                        "production": {
                            "budgetThreshold": 0,
                            "outputHashing": "all",
                            "sourceMap": false,
                            "namedChunks": false,
                            "extractLicenses": true,
                            "optimization": {
                                "styles": false,
                                "scripts": true,
                                "fonts": true
                            }
                        },
                        "development": {
                            "optimization": false,
                            "sourceMap": true
                        }
                    },
                    "defaultConfiguration": "development"
                },
                "serve": {
                    "builder": "@angular-devkit/build-angular:dev-server",
                    "configurations": {
                        "development": {
                            "browserTarget": "fw-portal:build:development"
                        },
                        "production": {
                            "browserTarget": "fw-portal:build:production"
                        }
                    },
                    "defaultConfiguration": "development"
                },
                "extract-i18n": {
                    "builder": "@angular-devkit/build-angular:extract-i18n"
                },
                "test": {
                    "builder": "@angular-devkit/build-angular:karma",
                    "options": {
                        "main": "src/test.ts",
                        "polyfills": [
                            "src/polyfills.ts"
                        ],
                        "tsConfig": "tsconfig.spec.json",
                        "karmaConfig": "karma.conf.js",
                        "styles": [
                            "src/styles.css"
                        ],
                        "scripts": [],
                        "assets": [
                            "src/favicon.ico",
                            "src/assets"
                        ]
                    }
                },
                "lint": {
                    "builder": "@angular-eslint/builder:lint"
                }
            }
        }
    },
    "cli": {
        "packageManager": "npm",
        "analytics": "14e47fbb 6cda1929 1130882b"
    }
}