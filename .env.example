# Azure AD Configuration (for production)
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Application Settings
SECRET_KEY=change-this-to-a-secure-random-string
DEBUG=True
ENVIRONMENT=development
AUTH_PROVIDER=azure_ad

# Database (using docker-compose services)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/fw_portal
REDIS_URL=redis://localhost:6379/0

# CORS
ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:80,http://localhost:3000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Frontend
FRONTEND_URL=http://localhost:80